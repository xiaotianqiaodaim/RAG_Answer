<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">




<mapper namespace="org.paismart.pai_test.Mapper.OrganizationTagsMapper">

    <insert id="createOrganization">
        insert into organization_tags (tag_id,created_at,description,name,parent_tag,updated_at,created_by) values
        (#{tagId},#{createdAt},#{description},#{name},#{parentTag},#{updatedAt},#{createdBy})
    </insert>

    <select id="findById" resultType="org.paismart.pai_test.entity.OrganizationTags">
        select * from organization_tags where tag_id=#{tagId}
    </select>
    <select id="getAll" resultType="org.paismart.pai_test.entity.OrganizationTags">
        select * from organization_tags
    </select>


</mapper>
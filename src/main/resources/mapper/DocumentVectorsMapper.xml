<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.paismart.pai_test.Mapper.DocumentVectorsMapper">
    <insert id="save">
        insert into document_vectors
        (vector_id,chunk_id,file_md5,is_public,org_tag,text_content,user_id)
        values(#{vectorId},#{chunkId},#{fileMd5},#{isPublic},#{orgTag},#{textContent},#{userId})
    </insert>
    <delete id="deleteByMd5">
        delete from document_vectors where file_md5=#{MD5}
    </delete>

    <select id="findByMd5" resultType="org.paismart.pai_test.entity.DocumentVectors">
        select * from document_vectors where file_md5=#{MD5}
        order by vector_id asc
    </select>

</mapper>